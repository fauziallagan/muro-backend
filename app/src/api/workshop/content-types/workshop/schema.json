{
  "kind": "collectionType",
  "collectionName": "workshops",
  "info": {
    "singularName": "workshop",
    "pluralName": "workshops",
    "displayName": "workshop"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "ws_category": {
      "type": "enumeration",
      "enum": [
        "Semester 1",
        "Semester 2",
        "Semester 3",
        "Semester 4",
        "Semester 5",
        "Semester 6"
      ]
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "level": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Beginner",
        "Intermediate",
        "Advance"
      ]
    },
    "workshop": {
      "type": "component",
      "component": "shared.testing",
      "repeatable": false
    },
    "ws_name": {
      "type": "enumeration",
      "enum": [
        "Drone",
        "Mikrokontroler Agroteknologi",
        "Mikrokontroler Kesehatan",
        "Raspberry Pi - Dasar",
        "Raspberry Pi - Robot",
        "Raspberry Pi - Face Recognition"
      ]
    },
    "description": {
      "type": "text"
    },
    "title": {
      "type": "string",
      "default": "Workshop"
    }
  }
}
